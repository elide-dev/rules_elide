# Bazel
bazel-*
.bazel/

# MODULE.bazel.lock format is not portable across Bazel major versions
# (7 -> v11, 8 -> v24, 9 -> separate schema). Multi-version CI cannot
# share a single committed lockfile; each runner regenerates its own.
MODULE.bazel.lock

# Benchmark workspace: gen.sh emits these per run; bench_suite.sh exports here.
benchmarks/sources/
benchmarks/results/

# Python bytecode + CodSpeed local run artifacts (benchmark harness).
__pycache__/
*.pyc
.codspeed/

# Editors / IDEs
.idea/
*.iml
.vscode/
.fleet/
*.swp
*~

# OS
.DS_Store
Thumbs.db
