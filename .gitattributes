# Files excluded from `git archive` / release tarballs.
# NOTE: do NOT export-ignore `e2e` wholesale — `e2e/smoke` is the BCR test
# module (`.bcr/presubmit.yml` -> bcr_test_module: module_path: e2e/smoke) and
# MUST ship in the released archive that BCR extracts. Exclude the other,
# heavier e2e workspaces individually instead; `e2e/smoke` stays in the archive.
e2e/abi_avoidance export-ignore
e2e/ic_correctness export-ignore
e2e/integration export-ignore
e2e/kotlin_builder export-ignore
e2e/rbe export-ignore
e2e/vanilla export-ignore
e2e/gen_fixture.py export-ignore
tests export-ignore
tools export-ignore
docs/BUILD.bazel export-ignore
.github export-ignore
.bcr export-ignore
.pre-commit-config.yaml export-ignore
.typos.toml export-ignore
.editorconfig export-ignore
.gitattributes export-ignore
.gitignore export-ignore

# LF everywhere.
* text=auto eol=lf
*.bat text eol=crlf

# Generated e2e benchmark fixture (e2e/gen_fixture.py): mark as generated so it
# is collapsed in PR diffs, skipped by code review (Copilot), and left out of
# language stats. Regenerate via gen_fixture.py rather than editing by hand.
e2e/vanilla/gen/** linguist-generated=true
e2e/integration/gen/** linguist-generated=true
