# Bzlmod is the only supported external-dep mode.
common --enable_bzlmod
# Default lockfile_mode=update: Bazel quietly maintains a local
# MODULE.bazel.lock (not committed — see .gitignore — because the schema
# is not portable across Bazel 7/8/9 majors).

# Stricter sandboxing defaults.
build --incompatible_strict_action_env
build --sandbox_default_allow_network=false

# Include JAVA_HOME/GRAALVM_HOME in the ElideNativeImage action cache key.
# The value enters the action via use_default_shell_env=True in the rule itself;
# --action_env here ensures a change in the JDK path invalidates cached outputs.
build --action_env=JAVA_HOME
build --action_env=GRAALVM_HOME

# protobuf 5+ (pulled in transitively via stardoc) requires C++17.
build --cxxopt=-std=c++17
build --host_cxxopt=-std=c++17

# Reproducibility helpers.
build --remote_download_outputs=toplevel
test --test_output=errors

# CI fragment; activate with `--config=ci`.
common:ci --color=yes
common:ci --terminal_columns=120
build:ci --noshow_progress
build:ci --show_timestamps
test:ci --test_output=errors
test:ci --test_summary=detailed

# --- Remote build: BuildBuddy RBE + cache + Build Event Stream ----------------
# Opt-in by design: this is a public ruleset, so remote is never on by default
# (that would break keyless/fork builds). CI passes --config=remote with the
# key; local builds stay local unless a dev opts in. The API key is NEVER
# committed — it is injected via user.bazelrc (see try-import below) as:
#   common --remote_header=x-buildbuddy-api-key=<KEY>
#
#   --config=buildbuddy   BES + remote cache (no remote execution)
#   --config=rbe          the above + remote execution on the RBE platform
#   --config=remote       alias for --config=rbe (the usual entrypoint)

# BES + remote cache.
common:buildbuddy --bes_results_url=https://elide-dev.buildbuddy.io/invocation/
common:buildbuddy --bes_backend=grpcs://elide-dev.buildbuddy.io
common:buildbuddy --remote_cache=grpcs://elide-dev.buildbuddy.io
common:buildbuddy --remote_cache_compression
common:buildbuddy --remote_upload_local_results
common:buildbuddy --remote_timeout=3h

# Remote execution on top of the cache. The Elide toolchain ships its native
# binary to the executor as an action input, so the stock public glibc image
# works (no custom worker image needed); see //tools/platforms.
#
# host_platform + extra_execution_platforms pin both the host and execution
# platform to the Linux/x86_64 RBE platform, so `--config=rbe`/`=remote`
# assumes a Linux x86_64 build host — which CI provides. On a non-Linux host,
# use `--config=buildbuddy` (remote cache + BES only, executes locally).
common:rbe --config=buildbuddy
common:rbe --remote_executor=grpcs://elide-dev.buildbuddy.io
common:rbe --host_platform=//tools/platforms:rbe_linux_amd64
common:rbe --extra_execution_platforms=//tools/platforms:rbe_linux_amd64
# Persistent workers are a *local* optimization (Bazel does not run them on the
# remote executor); force Elide's supported one-shot compiles under RBE so every
# compile is a plain remote action, with no local worker strategy in the way.
common:rbe --//elide:use_workers=false
common:rbe --jobs=50

# Convenience alias: full remote (cache + execution).
common:remote --config=rbe

# Local user overrides (incl. the BuildBuddy API key — keep out of git).
try-import %workspace%/user.bazelrc
